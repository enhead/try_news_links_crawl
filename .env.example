# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me_in_production
DB_DATABASE=news_crawl
DB_POOL_SIZE=20
DB_POOL_RECYCLE=3600
DB_ECHO=false

# ============================================
# HTTP 配置
# ============================================

# HTTP 适配器选择
# - curl_cffi: 使用 curl_cffi（推荐，可绕过 Cloudflare 等反爬虫）
# - httpx: 使用 httpx（标准 HTTP 客户端）
HTTP_DEFAULT_ADAPTER=curl_cffi

# curl_cffi 特有配置
# 模拟浏览器类型（TLS 指纹伪装）
# 可选值：chrome120, chrome110, chrome99, safari15_5, safari15_3, edge101, edge99
HTTP_CURL_CFFI_IMPERSONATE=chrome120

# 通用超时配置（适用于所有适配器）
HTTP_TIMEOUT=30
HTTP_CONNECT_TIMEOUT=5
HTTP_READ_TIMEOUT=15
HTTP_WRITE_TIMEOUT=5
HTTP_POOL_TIMEOUT=5

# 连接池配置
HTTP_MAX_CONNECTIONS=20
HTTP_MAX_KEEPALIVE_CONNECTIONS=10

# ============================================
# 应用配置
# ============================================
APP_ENV=development
LOG_LEVEL=INFO

# ============================================
# 新闻源模块配置
# ============================================
# 要导入的新闻源配置模块路径（逗号分隔，支持多个）
# 示例：
#   单个：NEWS_SOURCE_MODULES=v1.DDD.app.src.resource.news_source
#   多个：NEWS_SOURCE_MODULES=v1.DDD.app.src.resource.news_source,v1.DDD.app.src.resource.extra_sources
NEWS_SOURCE_MODULES=v1.DDD.app.src.resource.news_source
